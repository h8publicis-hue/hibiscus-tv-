rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /contents/{fileName} {
      // Mídias exibidas nas TVs precisam ser publicamente legíveis.
      allow read: if true;

      // Apenas usuários autenticados podem enviar arquivos, respeitando
      // tipo (imagem/vídeo) e tamanho máximo (200MB cobre o limite de
      // vídeo; a validação fina de 10MB para imagem também é feita no
      // frontend em lib/storage.ts).
      allow create, update: if request.auth != null
        && request.resource.size < 200 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/(jpeg|jpg|png|webp)')
          || request.resource.contentType.matches('video/(mp4|webm)')
        );

      allow delete: if request.auth != null;
    }
  }
}
